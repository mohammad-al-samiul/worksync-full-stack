# PostgreSQL connection (app runtime — use pooler URL on Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct connection for migrations / prisma db push (Supabase port 5432)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Local development example:
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/worksync?schema=public"

# JWT signing secret — use a long random string in production
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Next.js
NODE_ENV="development"
