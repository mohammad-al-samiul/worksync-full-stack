# =============================================================================
# Supabase (use BOTH URLs)
# =============================================================================
# App + seed — Transaction pooler (port 6543). Do NOT add sslmode here (handled in code).
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Prisma CLI — db push / migrate (port 5432, session or direct)
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# =============================================================================
# Local PostgreSQL
# =============================================================================
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/worksync?schema=public"

# JWT signing secret (change in production)
JWT_SECRET="change-me-to-a-long-random-secret"

# Next.js
NODE_ENV="development"
